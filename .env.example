# SoulGraph monorepo — copy to backend/.env and configure

APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=soulgraph
DB_USERNAME=soulgraph
DB_PASSWORD=secret

GPTUNNEL_API_KEY=your_key_here

NEO4J_URI=bolt://localhost:7687
NEO4J_PASSWORD=soulgraph_secret

QDRANT_HOST=localhost
